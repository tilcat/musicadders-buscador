# Copia este archivo a .env.local y rellena los valores.
# NUNCA subas .env.local al repo.

# Token compartido con el backend FastAPI (svc/).
# Debe coincidir con INTERNAL_TOKEN del backend.
# IMPORTANTE: esta variable NO debe tener prefijo NEXT_PUBLIC_ —
# solo el servidor Next.js debe acceder a ella.
INTERNAL_TOKEN=

# Clave de cifrado de sesión iron-session (mín. 32 caracteres, aleatorio).
# Genera con: openssl rand -base64 32
SESSION_SECRET=

# La cookie es secure=true por defecto (apta para HTTPS en producción).
# En desarrollo local sin HTTPS, desactivar explícitamente:
# COOKIE_SECURE=false

# ── F4 + F5: Spotify Playlist y Admin panel ──────────────────────────────────
# Emails con permiso para acceder a /api/playlist/setup/* (F4) y al panel de
# administración de usuarios /admin (F5). CSV sin espacios, fail-closed
# (si no está configurado, nadie tiene acceso a esas rutas).
# IMPORTANTE: esta variable NO debe tener prefijo NEXT_PUBLIC_ —
# solo el servidor Next.js debe acceder a ella.
# Debe coincidir con SPOTIFY_CENTRAL_ADMINS del backend (svc/).
SPOTIFY_CENTRAL_ADMINS=

# URL base de la aplicación (sin barra final).
# Usada para construir el redirect_uri del callback OAuth de Spotify.
# Ejemplo producción: https://buscador.musicadders.com
# Ejemplo local:      http://localhost:3000
APP_BASE_URL=http://localhost:3000
