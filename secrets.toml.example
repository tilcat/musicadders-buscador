# Pega esto en Streamlit Cloud → Manage app → Settings → Secrets (UI).
# NO lo subas al repo: este archivo es solo plantilla.

SOUNDCHARTS_APP_ID = "tu_app_id"
SOUNDCHARTS_API_KEY = "tu_api_key"
SOUNDCHARTS_MAX_PER_DAY = "5000"

# Usuarios y passwords (bcrypt hash). Generar hash con:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'tu_password', bcrypt.gensalt()).decode())"
# El email se compara en minúsculas, así que ponlo todo en minúsculas.
[users]
"victor@musicadders.com" = "$2b$12$REEMPLAZAR_CON_HASH_REAL_DE_BCRYPT"
"ana@musicadders.com"    = "$2b$12$REEMPLAZAR_CON_HASH_REAL_DE_BCRYPT"
