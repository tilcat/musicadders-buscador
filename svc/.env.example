# Credenciales Soundcharts (obligatorias)
SOUNDCHARTS_APP_ID=
SOUNDCHARTS_API_KEY=

# Límite diario de llamadas Soundcharts (opcional; default 5000 en app.py original)
# El svc no aplica este límite directamente — es informativo para el operador.
SOUNDCHARTS_MAX_PER_DAY=5000

# Token compartido entre Next.js y este servicio (obligatorio, fail-closed)
INTERNAL_TOKEN=

# ── F4: Spotify Playlist ─────────────────────────────────────────────────────
# App registrada en developer.spotify.com (obligatoria para F4)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Emails con permiso para gestionar la cuenta Spotify central (CSV, fail-closed)
# Ejemplo: admin@ejemplo.com,otro@ejemplo.com
SPOTIFY_CENTRAL_ADMINS=

# (Opcional) ID del usuario Spotify esperado en el flujo OAuth.
# Si se configura, el intercambio de code falla si el usuario no coincide.
# Obtener con: GET https://api.spotify.com/v1/me (campo "id")
SPOTIFY_CENTRAL_EXPECTED_USER_ID=

# (Semilla opcional) Refresh token inicial si ya tienes uno del flujo anterior.
# El flujo OAuth normal guarda el token en svc/data/spotify_central_token.json.
# CRÍTICO: nunca subir este valor al repo.
SPOTIFY_CENTRAL_REFRESH_TOKEN=

# URL base de la aplicación Next.js (sin barra final).
# Usada para construir el redirect_uri del callback OAuth de Spotify.
# Ejemplo producción: https://buscador.musicadders.com
# Ejemplo local:      http://localhost:3000
APP_BASE_URL=http://localhost:3000
